# ---- Application ----
PROJECT_NAME=Shizuka University CRM
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# ---- PostgreSQL ----
# Inside Docker Compose use POSTGRES_HOST=db ; for bare-metal dev use localhost
POSTGRES_USER=shizuka
POSTGRES_PASSWORD=shizuka
POSTGRES_DB=shizuka_crm
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- Security (CHANGE IN PRODUCTION) ----
JWT_SECRET_KEY=super-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Bootstrap Head Admin (created on first startup) ----
HEAD_ADMIN_EMAIL=admin@shizuka.io
HEAD_ADMIN_PASSWORD=Admin@12345
HEAD_ADMIN_NAME=Platform Owner

# ---- CORS (comma-separated) ----
CORS_ORIGINS=http://localhost:3000
